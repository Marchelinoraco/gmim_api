# ────────────────────────────────────────────────────────────────
# .env PRODUCTION untuk gmim_api — salin ke /var/www/gmim_api/.env
# Ganti nilai <...> sesuai server Anda.
# ────────────────────────────────────────────────────────────────
APP_NAME="GMIM Keuangan"
APP_ENV=production
APP_KEY=                          # diisi oleh: php artisan key:generate
APP_DEBUG=false
APP_URL=https://api.gmim.web.id
APP_VERSION=1.0.0

# URL frontend manage (untuk link di email & redirect)
FRONTEND_URL=https://app.gmim.web.id

APP_LOCALE=id
APP_TIMEZONE=Asia/Makassar       # WITA — Sulawesi Utara

# ── Database (self-host MySQL 8 di VPS yang sama) ──
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gmim_api
DB_USERNAME=gmim
DB_PASSWORD=<password-db-kuat>

# ── Session / Cache / Queue ──
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database         # cukup untuk mulai; Redis bisa menyusul

# ── CORS — izinkan semua subdomain gmim.web.id otomatis ──
CORS_ALLOWED_DOMAIN=gmim.web.id
CORS_ALLOWED_ORIGINS=https://app.gmim.web.id,https://admin.gmim.web.id

# ── Token Sanctum ──
SANCTUM_TOKEN_EXPIRY_DAYS=30

# ── Email (sementara 'log'; ganti ke SMTP provider saat siap) ──
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@gmim.web.id"
MAIL_FROM_NAME="GMIM Keuangan"

# ── Midtrans platform (langganan) — isi saat mengaktifkan billing ──
# MIDTRANS_PLATFORM_SERVER_KEY=
# MIDTRANS_PLATFORM_CLIENT_KEY=
# MIDTRANS_PLATFORM_IS_PRODUCTION=false

LOG_CHANNEL=stack
LOG_LEVEL=warning
